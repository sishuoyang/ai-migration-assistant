# ── LLM Provider (configure at least one) ────────────────────
# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
# OPENAI_API_KEY=sk-your-key-here

# Google Gemini
# GOOGLE_KEY=your-key-here

# AWS Bedrock
# BEDROCK_AWS_DEFAULT_REGION=us-east-1
# BEDROCK_AWS_ACCESS_KEY_ID=your-key-here
# BEDROCK_AWS_SECRET_ACCESS_KEY=your-secret-here

# Local Ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434


# ── Agent Provider / Model ────────────────────────────────────
# The three pre-built migration agents (Postgres, Snowflake, ClickHouse OSS)
# each default to whichever API key is set above. Override globally or
# per-source. Use LibreChat provider casing exactly:
#   anthropic | openAI | google | bedrock | azureOpenAI
#
# Global default (applies to all three agents unless overridden):
# AGENT_PROVIDER=anthropic
# AGENT_MODEL=claude-sonnet-4-6
#
# Per-source overrides — hyphens in source IDs become underscores:
# AGENT_PROVIDER_POSTGRES=anthropic
# AGENT_MODEL_POSTGRES=claude-sonnet-4-6
# AGENT_PROVIDER_SNOWFLAKE=openAI
# AGENT_MODEL_SNOWFLAKE=gpt-4o
# AGENT_PROVIDER_BIGQUERY=anthropic
# AGENT_MODEL_BIGQUERY=claude-sonnet-4-6
# AGENT_PROVIDER_CLICKHOUSE_OSS=anthropic
# AGENT_MODEL_CLICKHOUSE_OSS=claude-haiku-4-5-20251001
#
# Changing any of these after first start requires `make reset-agent`.
# (Partners can also edit each agent's model directly in the LibreChat UI.)


# ── LibreChat Host URL ────────────────────────────────────────
# Required for OAuth callbacks (e.g. ClickHouse Cloud MCP sign-in).
# On localhost leave these as-is. On a remote server set both to your
# Public URL of this deployment (no trailing slash).
# For remote servers use https:// — artifacts require a secure context (HTTPS).
# Example: https://13.250.15.68  (nginx proxy handles TLS on port 443)
DOMAIN_CLIENT=https://localhost
DOMAIN_SERVER=https://localhost

# ── LibreChat Security (change these before sharing) ─────────
JWT_SECRET=playground-jwt-secret-change-me-32x
JWT_REFRESH_SECRET=playground-refresh-secret-32xx
CREDS_KEY=f34be427ebb29de8d88c107a71546019685ed8b241d8f2ed00c3df97ad2566f0
CREDS_IV=e2341419ec3dd3d19b13a1a87fafcbfb

# ── Langfuse Observability (optional) ────────────────────────
# Traces every LLM call in LibreChat: token usage, latency, full conversation flow.
# Sign up free at https://cloud.langfuse.com → Settings → API Keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Dataset Size (small / medium / large) ────────────────────
# small:  ~1M events,  seed ~1 min
# medium: ~10M events, seed ~5-10 min  (default)
# large:  ~30M events, seed ~20-30 min
DATASET_SIZE=medium

# ── Postgres Source ──────────────────────────────────────────
# The migration-runner reads these to connect to a source Postgres
# instance. Same two scenarios as ClickHouse OSS below:
#
#   (a) Using the playground's bundled postgres container (e-commerce
#       demo workload):
#       Leave POSTGRES_HOST UNSET. The Python connector defaults to the
#       Docker service name `postgres`, reachable in-container. The
#       built-in user / password are `playground` / `playground` and
#       the database is `ecommerce`.
#
#   (b) Bring-your-own external Postgres:
#       Set POSTGRES_HOST to a hostname reachable from the
#       migration-runner container, plus user / password / database.
#
# DO NOT set `POSTGRES_HOST=localhost` — inside the migration-runner
# container, `localhost` resolves to the container itself, never to
# either the bundled service or your laptop.
#
# POSTGRES_HOST=postgres                   # (a) bundled, optional — default
# POSTGRES_HOST=my-pg.company.com          # (b) BYO external
# POSTGRES_PORT=5432
# POSTGRES_USER=your_user
# POSTGRES_PASSWORD=your_password
# POSTGRES_DB=your_source_db

# ── ClickHouse OSS Source ────────────────────────────────────
# The migration-runner reads these to connect to a source ClickHouse
# OSS instance. TWO common scenarios:
#
#   (a) Using the playground's bundled clickhouse-oss container:
#       Leave CH_OSS_HOST UNSET. The Python connector defaults to the
#       Docker service name `clickhouse-oss`, reachable in-container.
#
#   (b) Bring-your-own external ClickHouse OSS:
#       Set CH_OSS_HOST to a hostname reachable from the
#       migration-runner container (e.g. `my-ch.company.com` over the
#       internet, or `host.docker.internal` if it's on your laptop's
#       loopback on Mac/Windows).
#
# DO NOT set `CH_OSS_HOST=localhost` — inside the migration-runner
# container, `localhost` resolves to the container itself, never to
# either the bundled service or your laptop.
#
# CH_OSS_HOST=clickhouse-oss            # (a) bundled, optional — default
# CH_OSS_HOST=my-ch.company.com          # (b) BYO external
# CH_OSS_PORT=8123
# CH_OSS_USER=default
# CH_OSS_PASSWORD=
# CH_OSS_DB=analytics

# ── ClickHouse Cloud Target ───────────────────────────────────
# Required: set these before running migration scripts OR using the write MCP.
# The clickhousectl-mcp service reads these at startup — restart
# `docker compose up -d clickhousectl-mcp` after changing them.
# CLICKHOUSE_CLOUD_HOST=<your-service>.clickhouse.cloud
# CLICKHOUSE_CLOUD_USER=default
# CLICKHOUSE_CLOUD_PASSWORD=<your-password>
# CLICKHOUSE_CLOUD_DATABASE=default

# ── Snowflake Source (only for the snowflake migration source) ───
# Free trial: https://signup.snowflake.com
# Required to run snowflake-source MCP and the workload setup script.
#   make snowflake-setup   — copies TPC-H tables into MIGRATION_DEMO.RETAIL
#                            and applies Snowflake-specific augmentations
#                            (VARIANT, TIMESTAMP_TZ, Stream, Dynamic Table)
#   make up-snowflake      — starts the snowflake-source MCP container
# SNOWFLAKE_ACCOUNT=<orgname>-<accountname>
# SNOWFLAKE_USER=<user>
# SNOWFLAKE_PASSWORD=<password>
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_ROLE=

# ── S3 staging for large Snowflake → ClickHouse Cloud migrations ──
# Optional. When set, the agent can use `m.add_table_via_s3(...)` in the
# migrationkit script to bulk-export a table via Snowflake `COPY INTO
# @ext_stage` (Parquet) → ClickHouse Cloud `INSERT FROM s3(...)`.
# Typically ~10× faster than the direct-INSERT path on tables >1M rows.
#
# Setup notes (one-time, partner-managed):
#   1. Create or reuse an S3 bucket in the same region as your Snowflake
#      account.
#   2. Attach a bucket policy giving Snowflake's S3 integration role:
#      s3:PutObject, s3:DeleteObject, s3:GetObject, s3:ListBucket on
#      <bucket>/<prefix>/*.
#   3. Set the env vars below and re-run `docker compose up -d migration-runner`.
# Full walk-through: docs/object-storage-staging.md.
# STAGING_S3_BUCKET=my-migration-bucket
# STAGING_S3_REGION=us-east-1
# STAGING_S3_ACCESS_KEY_ID=<aws-access-key>
# STAGING_S3_SECRET_ACCESS_KEY=<aws-secret>
# STAGING_S3_PREFIX=migrationkit

# ── BigQuery Source (only for the bigquery migration source) ─────
# A GCP project + a service account JSON key with:
#   - roles/bigquery.dataEditor on the target dataset
#   - roles/bigquery.jobUser    on the project
# Required to run bigquery-source MCP and the workload setup script.
#   make tpch-data         — one-time TPC-H SF1 .tbl generation (local)
#   make tpch-load-bigquery — loads TPC-H + BigQuery augmentations
#                             (STRUCT, ARRAY<STRUCT>, partition+cluster, MV)
#   make up-bigquery       — starts the bigquery-source MCP container
#   make bigquery-provision — alternative: Terraform-creates dataset + SA
#                             key, writes ./secrets/gcp-key.json
# BIGQUERY_PROJECT=my-gcp-project
# BIGQUERY_DATASET=migration_demo
# BIGQUERY_LOCATION=US
# BIGQUERY_KEY_FILE=./secrets/gcp-key.json

# ── GCS staging for large BigQuery → ClickHouse Cloud migrations ──
# Optional. When set, the agent can use Path 2: BigQuery `EXPORT DATA`
# to GCS Parquet → ClickHouse Cloud `INSERT FROM gcs(...)`. Typically
# ~10× faster than the direct INSERT path on tables >1M rows.
#
# Setup notes (one-time, partner-managed — or auto-provisioned by
# `make bigquery-provision` with create_staging_bucket=true in
# terraform.tfvars):
#   1. Create or reuse a GCS bucket in the same region as your BigQuery
#      dataset.
#   2. Grant the BigQuery service account roles/storage.objectAdmin on
#      the bucket.
#   3. Create HMAC keys for the same service account — ClickHouse Cloud's
#      gcs() table function authenticates via HMAC, not the SA JSON:
#        gcloud iam service-accounts hmac-keys create \
#          --service-account-email <sa-email>
#      The output gives you the access ID and secret; drop both below.
#   4. Set the env vars below and re-run `docker compose up -d migration-runner`.
# STAGING_GCS_BUCKET=my-migration-bucket
# STAGING_GCS_PROJECT=my-gcp-project           # optional — defaults to BIGQUERY_PROJECT
# STAGING_GCS_PREFIX=migrationkit              # optional — namespace inside the bucket
# STAGING_GCS_KEY_FILE=./secrets/gcp-key.json  # optional — defaults to BIGQUERY_KEY_FILE
# STAGING_GCS_ACCESS_KEY_ID=<hmac-access-id>
# STAGING_GCS_SECRET_ACCESS_KEY=<hmac-secret>
